{
  "version": 2,
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "/res", "dest": "/api/res.php" },
    { "src": "/form", "dest": "/api/form.php" },
    { "src": "/view/(?<id>.*)", "dest": "/api/view.php?id=$id" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/api/index.php" }
  ]
}